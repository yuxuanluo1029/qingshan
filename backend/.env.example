PORT=3000
CORS_ORIGIN=http://localhost:5173

# AI provider: aliyun | tencent | auto
AI_PROVIDER=aliyun

# Aliyun DashScope (Qwen, server-side only)
ALIYUN_API_KEY=
ALIYUN_MODEL=qwen-plus
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Tencent Hunyuan credentials (server-side only, optional fallback)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_HUNYUAN_REGION=ap-guangzhou
TENCENT_HUNYUAN_MODEL=hunyuan-turbos-latest

# Optional: Mamba VDT saliency pre-processing for image identification
# If omitted, the identify API still works with similarity matching fallback.
MAMBA_CODE_DIR=C:\Users\Lenovo\Desktop\基于 Mamba 的轻量级 VDT显著目标检测网络算法\1.代码源文件
MAMBA_WEIGHTS_PATH=C:\Users\Lenovo\Desktop\基于 Mamba 的轻量级 VDT显著目标检测网络算法\1.代码源文件\model_best.pth

# Tencent Map key for frontend (.env in frontend)
# VITE_TENCENT_MAP_KEY=
